    create table "iceberg"."bronze_raw_bronze"."bronze_inventory_snapshots__dbt_tmp"
      
      
    as (
      

SELECT
   snapshot_id, 
   product_id, 
   warehouse_id, 
   CAST(snapshot_date AS DATE) as snapshot_date,
