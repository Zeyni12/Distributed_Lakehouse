    create table "iceberg"."bronze_raw_silver"."silver_customer_events"
      
      
    as (
      

WITH source AS (
    SELECT * FROM "iceberg"."bronze_raw_bronze"."bronze_customer_events"
),

cleaned AS (
    SELECT
        event_id,
        customer_id,
        session_id,
        event_type,
        event_timestamp,
        page_url,
        product_id,
        category_id,

        -- Normalize referrer source
        LOWER(TRIM(referrer_source))   AS referrer_source,

        -- Normalize device type
        LOWER(TRIM(device_type))   AS device_type,

        -- Mask PII
        TO_HEX(MD5(TO_UTF8(ip_address))) AS ip_address_hashed
        -- Derived fields
        -- first_response_minutes:
        DATE_DIFF('second', created_timestamp, first_response_timestamp) / 60.0

        -- resolution_minutes:
        DATE_DIFF('second', created_timestamp, CAST(resolution_timestamp AS TIMESTAMP)) / 60.0

        -- SLA breach CASE conditions:
        DATE_DIFF('second', created_timestamp, first_response_timestamp) / 60.0 > 60   -- high
        DATE_DIFF('second', created_timestamp, first_response_timestamp) / 60.0 > 240  -- medium
        DATE_DIFF('second', created_timestamp, first_response_timestamp) / 60.0 > 1440 -- low
        CASE
            WHEN LOWER(device_type) IN ('mobile', 'tablet')    THEN 'mobile'
            WHEN LOWER(device_type) = 'desktop'                THEN 'desktop'
            ELSE 'unknown'
        END    AS device_category,

        CASE
            WHEN product_id IS NOT NULL       THEN TRUE
            ELSE FALSE
        END         AS is_product_event,

        ingested_at,
        source_system,
        CURRENT_TIMESTAMP   AS transformed_at

    FROM source
    WHERE
        event_id        IS NOT NULL
        AND customer_id IS NOT NULL
        AND event_timestamp IS NOT NULL
        -- Remove future-dated events (data quality guard)
        AND event_timestamp <= CURRENT_TIMESTAMP
)

SELECT * FROM cleaned
    )
